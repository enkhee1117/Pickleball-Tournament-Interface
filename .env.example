# Supabase — public, safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New Supabase projects call this the publishable key. Older envs may use
# NEXT_PUBLIC_SUPABASE_ANON_KEY instead; the app accepts either name.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Public app URL (for invite/email links). On Vercel set to your prod domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
