# Supabase — public, safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New Supabase projects call this the publishable key. Older envs may use
# NEXT_PUBLIC_SUPABASE_ANON_KEY instead; the app accepts either name.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Public app URL (for invite/email links). Production: https://trytodink.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push (player-notify "You're on Court N" lock-screen push).
# Generate a key pair once with: npx web-push generate-vapid-keys
# The public key is exposed to the browser to subscribe; the private key is
# server-only and signs the pushes. When unset, push send is a logged no-op
# and the browser simply never subscribes.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for the push service (mailto: or https:).
VAPID_SUBJECT=mailto:notify@trytodink.com
